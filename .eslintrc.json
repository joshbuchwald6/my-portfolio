{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "react/no-unescaped-entities": 0,
    "@next/next/no-html-link-for-pages": "off",
    "@next/next/no-img-element": "off",
    "react/display-name": "off",
    "react/prop-types": "off"
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  }
} 